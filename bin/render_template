#!/usr/bin/env bash
#
# render-template.sh
# ------------------
# Purpose:
#   Renders Jinja templates using minijinja-cli.
#   - Accepts one or more YAML config files as arguments
#   - Each YAML can define:
#     - Flat: input_file, output_file + context variables
#     - Or:   renders: [ {input_file, output_file}, ... ] + shared context
#
# Requirements:
#   - yq (mikefarah/yq v4+)
#   - minijinja-cli
#
# Usage:
#   ./render-template.sh config.yaml
#   ./render-template.sh config1.yaml config2.yaml
#   ./render-template.sh parameters-*.yaml
#

set -euo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────────────────────────────────────

die() {
    echo "ERROR: ${1:-Unknown error}" >&2
    exit "${2:-1}"
}

check_command() {
    command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not installed."
}

render_single() {
    local config_file="$1"
    local input_rel output_file input_full config_dir

    config_dir=$(dirname "$(realpath "$config_file")")

    input_rel=$(yq -r '.input_file // ""' "$config_file")
    output_file=$(yq -r '.output_file // ""' "$config_file")

    [[ -z "$input_rel" ]] && die "Missing .input_file in $config_file"
    [[ -z "$output_file" ]] && die "Missing .output_file in $config_file"

    input_full="$config_dir/$input_rel"

    [[ -f "$input_full" ]] || die "Template not found: $input_full (from $config_file)"

    echo "Rendering single template from $config_file:"
    echo "  Template : $input_full"
    echo "  Output   : $output_file"
    echo "  Context  : $config_file"

    local output_dir
    output_dir=$(dirname "$output_file")
    [[ -d "$output_dir" ]] || {
        echo "Creating directory: $output_dir"
        mkdir -p "$output_dir" || die "Failed to create $output_dir"
    }

    minijinja-cli \
        --strict \
        "$input_full" \
        "$config_file" \
        > "$output_file.tmp" \
        || die "minijinja-cli failed on $input_rel (from $config_file)"

    mv "$output_file.tmp" "$output_file"
    echo "  → Done: $output_file"
}

render_multi() {
    local config_file="$1"
    local render_count i input_rel output_file input_full config_dir

    config_dir=$(dirname "$(realpath "$config_file")")

    render_count=$(yq '.renders | length // 0' "$config_file")
    [[ "$render_count" -eq 0 ]] && return 1  # not multi → let caller handle

    echo "Found $render_count template(s) in $config_file"

    for i in $(seq 0 $((render_count - 1))); do
        input_rel=$(yq -r ".renders[$i].input_file // \"\"" "$config_file")
        output_file=$(yq -r ".renders[$i].output_file // \"\"" "$config_file")

        [[ -z "$input_rel" ]] && die "Missing .renders[$i].input_file in $config_file"
        [[ -z "$output_file" ]] && die "Missing .renders[$i].output_file in $config_file"

        input_full="$config_dir/$input_rel"

        [[ -f "$input_full" ]] || die "Template not found: $input_full (from $config_file)"

        echo ""
        echo "  [$((i+1))/$render_count] $config_file → $input_rel"
        echo "     Output : $output_file"

        local output_dir
        output_dir=$(dirname "$output_file")
        [[ -d "$output_dir" ]] || mkdir -p "$output_dir" || die "Failed to create $output_dir"

        minijinja-cli \
            --strict \
            "$input_full" \
            "$config_file" \
            > "$output_file.tmp" \
            || die "minijinja-cli failed on $input_rel (from $config_file)"

        mv "$output_file.tmp" "$output_file"
        echo "     → Done"
    done

    return 0
}

# ──────────────────────────────────────────────────────────────────────────────
# Main logic
# ──────────────────────────────────────────────────────────────────────────────

[[ $# -eq 0 ]] && {
    echo "Usage: $0 <config.yaml> [config2.yaml ...]"
    echo "Processes each YAML file independently."
    exit 1
}

check_command yq
check_command minijinja-cli

for CONFIG_FILE in "$@"; do
    echo ""
    echo "══════════════════════════════════════════════════════════"
    echo "Processing config: $CONFIG_FILE"
    echo "══════════════════════════════════════════════════════════"

    [[ -f "$CONFIG_FILE" ]] || {
        echo "WARNING: Skipping — file not found: $CONFIG_FILE" >&2
        continue
    }

    # Try multi-render format first
    if render_multi "$CONFIG_FILE"; then
        :  # success, continue to next file
    else
        # Fall back to single-render format
        render_single "$CONFIG_FILE"
    fi
done

echo ""
echo "All config files processed."
exit 0
