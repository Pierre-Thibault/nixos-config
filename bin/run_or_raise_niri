#!/usr/bin/env bash

# Generic run-or-raise script for Niri
# Usage: run_or_raise_niri <app_id> <launch_command> [new_window_command]
#
# new_window_command is used when the app is already running (on another workspace)
# but has no window on the current one. Useful for singleton apps like Nautilus.
#
# Examples:
#   run_or_raise_niri "waterfox" "flatpak run net.waterfox.waterfox"
#   run_or_raise_niri "org.gnome.Nautilus" "nautilus" "nautilus --new-window"

if [ $# -lt 2 ]; then
    echo "Usage: $0 <app_id> <launch_command> [new_window_command]"
    exit 1
fi

APP_ID="$1"
LAUNCH_CMD="$2"
NEW_WINDOW_CMD="${3:-$2}"

# Get the currently focused workspace ID
current_workspace=$(niri msg --json workspaces | jq -r '.[] | select(.is_focused) | .id')

all_windows=($(niri msg --json windows | jq -r ".[] | select(.app_id | ascii_downcase | contains(\"${APP_ID,,}\")) | .id" | sort -n))

# Get all windows matching the app_id on current workspace, sorted by id
windows=($(niri msg --json windows | jq -r ".[] | select(.app_id | ascii_downcase | contains(\"${APP_ID,,}\")) | select(.workspace_id == $current_workspace) | .id" | sort -n))

if [ ${#windows[@]} -eq 0 ]; then
    if [ ${#all_windows[@]} -gt 0 ]; then
        # App is running on another workspace — open a new window here
        $NEW_WINDOW_CMD &
    else
        # No windows anywhere, launch a new instance
        $LAUNCH_CMD &
    fi
else
    # At least one window exists
    # Check if one of our app windows is currently focused
    focused_index=-1
    for i in "${!windows[@]}"; do
        is_focused=$(niri msg --json windows | jq -r ".[] | select(.id == ${windows[$i]}) | .is_focused")
        if [ "$is_focused" = "true" ]; then
            focused_index=$i
            break
        fi
    done

    if [ $focused_index -eq -1 ]; then
        # None of our app windows is focused, focus the first one
        niri msg action focus-window --id "${windows[0]}"
    else
        # One of our windows is focused, cycle to the next one
        next_index=$(( (focused_index + 1) % ${#windows[@]} ))
        niri msg action focus-window --id "${windows[$next_index]}"
    fi
fi
