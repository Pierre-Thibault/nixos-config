    subgraph sops["Secret Management — sops-nix"]
        encrypted["🔒 Encrypted secrets\ngit repository\n(age encryption)"]:::secret
        activation["NixOS activation\nat boot"]:::secret
        ram["/run/secrets/\nRAM tmpfs\nnever written to disk"]:::secret
